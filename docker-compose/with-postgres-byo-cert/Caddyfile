# Broch production Caddyfile — BYO wildcard cert
#
# Caddy uses a static cert+key pair you provide (mounted at /etc/caddy/certs/).
# No ACME, no DNS-01. Use this when:
#   - Your cert comes from a commercial CA
#   - Your team has internal PKI / a centralised cert renewal pipeline
#   - You're using certbot externally and copying the cert into ./certs/
#
# Renewal is YOUR responsibility — Caddy won't refresh these certs. Replace
# the files on disk and run `docker compose exec caddy caddy reload`.

{
	# Disable Caddy's automatic HTTPS — we're providing the cert ourselves.
	auto_https off

	# Default email retained for completeness; not used since auto_https is off.
}

# One catch-all block serves both the apex (the API endpoint customers and
# the CLI talk to) and every wildcard tunnel subdomain — with a static cert
# they were identical proxies anyway, and the cert itself bounds what clients
# accept. A catch-all is also required here: Caddy validates explicit-cert
# site addresses before {env.*} substitution, so a placeholder address like
# *.{env.BROCH_WILDCARD_HOSTNAME} fails to adapt ("subject does not qualify
# for certificate") and Caddy never starts.
:443 {
	tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.pem

	reverse_proxy broch:8080 {
		header_up Host {host}

		# Ride out brief broch unavailability (container restart / image
		# upgrade) by retrying the dial for up to 30s, instead of returning an
		# immediate 502. Mirrors the hosted ingress, which holds traffic across
		# a revision swap. Connection-level only — cannot mask a 5xx the broch
		# server itself returns. (BROCH-1016)
		lb_try_duration 30s
		lb_try_interval 250ms
	}
}

# HTTP → HTTPS redirect (Caddy won't do this automatically with auto_https off).
:80 {
	redir https://{host}{uri} permanent
}
