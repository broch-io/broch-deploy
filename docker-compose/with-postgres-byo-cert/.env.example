# Broch with-postgres-byo-cert configuration
#
#   1. Drop your wildcard cert at ./certs/fullchain.pem and ./certs/privkey.pem
#      (PEM format; mode 0644 fullchain, 0600 privkey)
#   2. cp .env.example .env  and fill in
#   3. docker compose up -d


# ── Required ─────────────────────────────────────────────────────────────────

# Broch master key — the at-rest encryption root. Required; the server won't
# start without it. Generate a strong random value: `openssl rand -base64 48`.
BROCH_MASTER_KEY=

# Must match the CN / SANs of your wildcard cert (e.g. cert covering both
# broch.example.com and *.broch.example.com)
BROCH_WILDCARD_HOSTNAME=broch.example.com

POSTGRES_PASSWORD=


# ── Identity provider (required at boot) ─────────────────────────────────────
#
# Broch authenticates every user through your IdP — there is no built-in local
# login, so the IdP is part of the boot floor. The server starts without these,
# but no one can sign in (or finish first-run setup) until they're set. Your
# first admin is whoever signs in holding a role named in ADMINROLES.
# Setup guides: https://broch.io/docs/identity-providers/

# Provider: Auth0 | AzureAd | EntraExternalId | Okta | Oidc
# (No inline comments after values — dotenv passes them through as part of
# the value and the server rejects it at boot.)
AUTHENTICATION__PROVIDER=
AUTHENTICATION__CLIENTID=
AUTHENTICATION__CLIENTSECRET=
# broch_admin is an example — replace with admin group(s)/role(s) from your
# own IdP that your first admin actually holds. Comma-separated; holding any
# listed role grants admin.
AUTHENTICATION__ADMINROLES=broch_admin

# Set the value(s) your provider needs; leave the rest blank:
#   Auth0 / Okta:     AUTHENTICATION__DOMAIN=your-tenant.auth0.com
#   AzureAd / Entra:  AUTHENTICATION__TENANTID + AUTHENTICATION__INSTANCE=https://login.microsoftonline.com/
#   Oidc (generic):   AUTHENTICATION__AUTHORITY=https://issuer.example.com
#   Auth0 RBAC:       AUTHENTICATION__AUDIENCE=<your-api-identifier>  (only if roles arrive via the access token)
AUTHENTICATION__DOMAIN=
AUTHENTICATION__TENANTID=
AUTHENTICATION__INSTANCE=
AUTHENTICATION__AUTHORITY=
AUTHENTICATION__AUDIENCE=


# ── Optional ─────────────────────────────────────────────────────────────────

# Broch license is activated in-app on first sign-in (Admin → License) — there's
# no env var for it. Buy a license at https://broch.io/pricing.

# Broch server image tag. Defaults to a concrete pinned version (see docker-compose.yml).
# Override to upgrade deliberately, or set BROCH_VERSION=latest to float (not recommended).
# BROCH_VERSION=1.26.0
# Image repo defaults to the public ghcr.io/broch-io/broch. Override only for a private mirror
# or a pre-release/beta image you've been granted (then `docker login` to that registry first):
# BROCH_IMAGE=ghcr.io/broch-io/broch
# POSTGRES_DB=brochdb
# POSTGRES_USER=broch
