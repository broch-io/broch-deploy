# Broch with-postgres-external + Caddy production configuration
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d --build


# ── Required ─────────────────────────────────────────────────────────────────

BROCH_LICENSE=

BROCH_WILDCARD_HOSTNAME=tunnels.example.com

# Caddy DNS-01 + Let's Encrypt
CADDY_ACME_EMAIL=
CLOUDFLARE_API_TOKEN=

# Connection string for your external Postgres. Format expected by Npgsql:
#
#   Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<pass>;SSL Mode=Require
#
# Examples:
#
#   DigitalOcean Managed:
#     Host=broch-db-do-user-1234.b.db.ondigitalocean.com;Port=25060;Database=brochdb;Username=broch;Password=xxx;SSL Mode=Require
#
#   AWS RDS:
#     Host=broch.abc123.us-east-1.rds.amazonaws.com;Port=5432;Database=brochdb;Username=broch;Password=xxx;SSL Mode=Require
#
#   Neon / Supabase (or any Postgres-as-a-service with TLS):
#     Host=ep-cool-name-12345.us-east-1.aws.neon.tech;Database=brochdb;Username=broch;Password=xxx;SSL Mode=Require
#
# SSL Mode values: Require (default for managed services), Prefer, Disable.
BROCH_DB_CONNECTION_STRING=


# ── Optional (defaults shown) ────────────────────────────────────────────────

# BROCH_VERSION=latest
