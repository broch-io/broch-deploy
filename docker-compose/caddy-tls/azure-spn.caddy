tls {
	dns azure {
		subscription_id {env.AZURE_DNS_SUBSCRIPTION_ID}
		resource_group_name {env.AZURE_DNS_RESOURCE_GROUP}
		tenant_id {env.AZURE_DNS_TENANT_ID}
		client_id {env.AZURE_DNS_CLIENT_ID}
		client_secret {env.AZURE_DNS_CLIENT_SECRET}
	}
	resolvers 1.1.1.1 8.8.8.8
	propagation_timeout 300s
}
