# Broch single-host configuration
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored at the
# repo root, so your secrets stay on your machine.
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d


# ── Required ─────────────────────────────────────────────────────────────────

# Broch master key — the at-rest encryption root. The server won't start
# without it. Generate a strong random value: `openssl rand -base64 48`.
BROCH_MASTER_KEY=

# Wildcard DNS hostname for tunnels. Drives the public URLs that Broch hands
# out to tunnel clients. For local testing you can use a hosts-file entry like
# `tunnels.local.test` and point it at 127.0.0.1.
BROCH_WILDCARD_HOSTNAME=tunnels.local.test

# Postgres password. Generate a strong one — this protects your broch state
# database on disk. Example: `openssl rand -base64 32`.
POSTGRES_PASSWORD=


# ── Identity provider (required at boot) ─────────────────────────────────────
#
# Broch authenticates every user through your IdP — there is no built-in local
# login, so the IdP is part of the boot floor. The server starts without these,
# but no one can sign in (or finish first-run setup) until they're set. Your
# first admin is whoever signs in holding a role named in ADMINROLES.
# Setup guides: https://broch.io/docs/identity-providers/

AUTHENTICATION__PROVIDER=               # Auth0 | AzureAd | EntraExternalId | Okta | Oidc
AUTHENTICATION__CLIENTID=
AUTHENTICATION__CLIENTSECRET=
AUTHENTICATION__ADMINROLES=broch_admin  # any role/group your first admin holds

# Set the value(s) your provider needs; leave the rest blank:
#   Auth0 / Okta:     AUTHENTICATION__DOMAIN=your-tenant.auth0.com
#   AzureAd / Entra:  AUTHENTICATION__TENANTID + AUTHENTICATION__INSTANCE=https://login.microsoftonline.com/
#   Oidc (generic):   AUTHENTICATION__AUTHORITY=https://issuer.example.com
AUTHENTICATION__DOMAIN=
AUTHENTICATION__TENANTID=
AUTHENTICATION__INSTANCE=
AUTHENTICATION__AUTHORITY=


# ── Optional ─────────────────────────────────────────────────────────────────

# Broch license key. Optional at boot — leave blank and activate in-app on first
# sign-in (Admin → License), or pre-seed it here for an unattended deployment.
# Buy a license at https://broch.io/pricing.
BROCH_LICENSE=

# Broch server image tag. Pin to a specific version in production — `latest`
# is fine for local testing only.
# BROCH_VERSION=latest

# Host port the broch HTTP listener binds to. Change if 8080 is taken.
# BROCH_HTTP_PORT=8080

# Postgres database name and user. The defaults match the connection string
# in docker-compose.yml — only change these if you have a reason.
# POSTGRES_DB=brochdb
# POSTGRES_USER=broch
