# Broch with-postgres + Caddy production configuration
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d --build


# ── Required ─────────────────────────────────────────────────────────────────

# Broch license key.
BROCH_LICENSE=

# Wildcard DNS hostname for tunnels and the API. Caddy issues both an apex
# cert (e.g. tunnels.example.com) and a wildcard cert (*.tunnels.example.com)
# rooted here, so this hostname must:
#   1. Be a real DNS name you control
#   2. Resolve to this host's public IP (apex A/AAAA record)
#   3. Have its DNS managed by Cloudflare (or swap the DNS provider — see
#      Caddy.Dockerfile and Caddyfile)
BROCH_WILDCARD_HOSTNAME=tunnels.example.com

# Email address Let's Encrypt notifies if your certs are about to expire and
# fail to renew. Use one you actually check.
CADDY_ACME_EMAIL=

# Cloudflare API token with Zone:Read + DNS:Edit permissions, scoped to the
# zone for BROCH_WILDCARD_HOSTNAME. Create at:
#   https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit zone DNS" template.
CLOUDFLARE_API_TOKEN=

# Postgres password. Generate with `openssl rand -base64 32`.
POSTGRES_PASSWORD=


# ── Optional (defaults shown) ────────────────────────────────────────────────

# Broch server image tag. Pin to a specific version in production.
# BROCH_VERSION=latest

# Postgres database name and user.
# POSTGRES_DB=brochdb
# POSTGRES_USER=broch
